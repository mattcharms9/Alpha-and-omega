  "crons": [
    { "path": "/api/cron/market-intelligence", "schedule": "0 1 * * *"   },
    { "path": "/api/cron/run-agent-queue",     "schedule": "0 2 * * *"   },
    { "path": "/api/cron/daily-brief",         "schedule": "0 8 * * *"   },
