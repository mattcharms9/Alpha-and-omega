    "src/app/api/cron/run-agent-queue/route.ts":        { "maxDuration": 300 },
    "src/app/api/cron/close-day/route.ts":              { "maxDuration": 120 },
    "src/app/api/cron/record-learning/route.ts":        { "maxDuration": 120 },
