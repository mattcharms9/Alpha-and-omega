{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "functions": {
    "src/app/api/products/batch/route.ts": { "maxDuration": 120 },
    "src/app/api/launch-queue/route.ts": { "maxDuration": 120 },
    "src/app/api/cron/run-agent-queue/route.ts": { "maxDuration": 300 },
    "src/app/api/generate-image/route.ts": { "maxDuration": 60 },
    "src/app/api/pdf/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron/run-agent-queue", "schedule": "0 2 * * *" },
    { "path": "/api/cron/daily-brief", "schedule": "0 8 * * *" }
  ]
}
