    "src/app/api/products/route.ts":                    { "maxDuration": 60 },
    "src/app/api/products/batch/route.ts":              { "maxDuration": 120 },
    "src/app/api/brands/route.ts":                      { "maxDuration": 60 },
    "src/app/api/market-research/route.ts":             { "maxDuration": 60 },
    "src/app/api/niche-expansion/route.ts":             { "maxDuration": 60 },
    "src/app/api/knowledge/route.ts":                   { "maxDuration": 60 },
    "src/app/api/games/route.ts":                       { "maxDuration": 60 },
    "src/app/api/empire/route.ts":                      { "maxDuration": 60 },
    "src/app/api/competitors/route.ts":                 { "maxDuration": 60 },
    "src/app/api/variants/route.ts":                    { "maxDuration": 60 },
    "src/app/api/generate-image/route.ts":              { "maxDuration": 60 },
    "src/app/api/pdf/route.ts":                         { "maxDuration": 60 },
    "src/app/api/launch-queue/route.ts":                { "maxDuration": 300 },
    "src/app/api/learning/route.ts":                    { "maxDuration": 60 },
    "src/app/api/bundles/route.ts":                     { "maxDuration": 60 },
    "src/app/api/etsy/shop/route.ts":                   { "maxDuration": 60 },
