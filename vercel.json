    { "path": "/api/cron/close-day",           "schedule": "59 23 * * *" },
    { "path": "/api/cron/weekly-report",       "schedule": "0 9 * * 0"   },
    { "path": "/api/cron/competitor-monitor",  "schedule": "0 4 * * 1"   },
    { "path": "/api/cron/daily-reminder",      "schedule": "0 21 * * *"  },
